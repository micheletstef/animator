{
  "defaultFontId": "inter-vf",
  "groups": [
    {
      "id": "condensed",
      "label": "Condensed",
      "fonts": [
        {
          "id": "arial-narrow",
          "label": "Arial Narrow",
          "stack": "Arial Narrow, 'Helvetica Neue', Helvetica, sans-serif"
        },
        {
          "id": "franklin-cond",
          "label": "Franklin Gothic Demi Cond",
          "stack": "'Franklin Gothic Demi Cond', 'Arial Narrow', Impact, sans-serif"
        },
        {
          "id": "bahnschrift-cond",
          "label": "Bahnschrift Condensed",
          "stack": "'Bahnschrift Condensed', 'Bahnschrift', 'Segoe UI', sans-serif"
        }
      ]
    },
    {
      "id": "extended",
      "label": "Extended",
      "fonts": [
        {
          "id": "arial-black",
          "label": "Arial Black",
          "stack": "'Arial Black', 'Arial Bold', Gadget, sans-serif"
        },
        {
          "id": "franklin-ext",
          "label": "Franklin Gothic Medium",
          "stack": "'Franklin Gothic Medium', 'Franklin Gothic', Arial, sans-serif"
        },
        {
          "id": "system-wide",
          "label": "System UI",
          "stack": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
        }
      ]
    },
    {
      "id": "variables",
      "label": "Variables",
      "fonts": [
        {
          "id": "inter-vf",
          "label": "Inter",
          "path": "variables/InterVariable.woff2",
          "cssFamily": "anim-inter-vf",
          "variable": true,
          "axes": [
            {
              "tag": "wght",
              "name": "Weight",
              "min": 100,
              "max": 900,
              "default": 450
            },
            {
              "tag": "slnt",
              "name": "Slant",
              "min": -10,
              "max": 0,
              "default": 0,
              "step": 0.5
            }
          ]
        }
      ]
    }
  ]
}
